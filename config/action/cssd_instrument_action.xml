<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<actions>
    <action>
        <name>cssd.instrument.submitRequirement</name>
        <label>手术室提交器械包需求</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentRequirementSubmitAction</clazz>
    </action>
    <action>
        <name>cssd.instrument.queryList</name>
        <label>查询器械包列表</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentQueryListAction</clazz>
    </action>
    <action>
        <name>cssd.instrument.queryByPk</name>
        <label>根据主键查询器械包</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentQueryByPkAction</clazz>
    </action>
    <action>
        <name>cssd.instrument.registerCleaning</name>
        <label>消毒员登记清洗</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentRegisterCleaningAction</clazz>
    </action>
    <action>
        <name>cssd.instrument.registerLack</name>
        <label>登记器械包缺件</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentRegisterLackAction</clazz>
    </action>
    <action>
        <name>cssd.instrument.resolveLack</name>
        <label>处理器械包缺件</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentResolveLackAction</clazz>
    </action>
    <action>
        <name>cssd.instrument.confirmRelease</name>
        <label>质控护士确认放行</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentConfirmReleaseAction</clazz>
    </action>
    <action>
        <name>cssd.instrument.sendToOR</name>
        <label>发放器械包到手术室</label>
        <clazz>nccloud.web.cssd.instrument.action.InstrumentSendToORAction</clazz>
    </action>
    <action>
        <name>cssd.sterbatch.create</name>
        <label>创建灭菌批次</label>
        <clazz>nccloud.web.cssd.instrument.action.SterBatchCreateAction</clazz>
    </action>
    <action>
        <name>cssd.sterbatch.finish</name>
        <label>完成灭菌批次</label>
        <clazz>nccloud.web.cssd.instrument.action.SterBatchFinishAction</clazz>
    </action>
    <action>
        <name>cssd.sterbatch.queryList</name>
        <label>查询灭菌批次列表</label>
        <clazz>nccloud.web.cssd.instrument.action.SterBatchQueryListAction</clazz>
    </action>
    <action>
        <name>cssd.lackrecord.queryList</name>
        <label>查询缺件记录列表</label>
        <clazz>nccloud.web.cssd.instrument.action.LackRecordQueryListAction</clazz>
    </action>
    <action>
        <name>cssd.releaserecord.queryList</name>
        <label>查询放行记录列表</label>
        <clazz>nccloud.web.cssd.instrument.action.ReleaseRecordQueryListAction</clazz>
    </action>
</actions>
